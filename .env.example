# 6pm 로컬 환경변수 — 템플릿(.env.example, 커밋 O). 실제값은 .env(커밋 X)에 채운다.
# 사용:  cp .env.example .env   →   .env 에 실제 값 입력
# 이 변수들은 (1) 각 서비스 application.yml 과 (2) docker-compose 가 함께 사용한다.

# ---------------- PostgreSQL ----------------
# ⚠️ currentSchema 는 "본인 서비스 스키마"로 바꿀 것!
#    user_db / feed_db / ticket_db / order_db / notify_db / aiops_db
#    (준영: user-service=user_db, aiops-service=aiops_db)
DB_URL=jdbc:postgresql://localhost:5432/fandom_db?currentSchema=user_db
DB_USERNAME=root
DB_PASSWORD=                 # ← .env 에서 실제 비밀번호. 비우면 postgres 컨테이너 기동 실패

# ---------------- Redis ----------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=              # ← .env 에서 실제 비밀번호

# 참고: docker-compose 는 위 DB_USERNAME/DB_PASSWORD/REDIS_PASSWORD 를 그대로 사용한다.
#   (postgres 컨테이너 POSTGRES_USER=${DB_USERNAME}, POSTGRES_PASSWORD=${DB_PASSWORD})
#   → .env 하나로 서비스와 컨테이너가 같은 자격증명을 쓰게 됨.