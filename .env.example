terraform output alb_dns_name# =====================================================================
# 6pm-fandom-sns · 환경변수 템플릿 (.env.example)
# =====================================================================
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채운다. (.env 는 git 에 커밋되지 않음)
#   cp .env.example .env
#
# 설계 원칙 (Production 대비):
#   * non-secret(URL/포트/DB명/Kafka 등): 로컬 기본값을 적어둔다 → 복사하면 바로 동작.
#   * secret(비밀번호/키): 기본값을 두지 않는다. 각자 .env 에 채우고, 운영에서는
#     시크릿 매니저(AWS Secrets Manager 등)가 동일 이름으로 주입한다.
#   * DB/계정은 현재 공용(root)이지만, 계정 분리(서비스별 전용 계정) 전환을 대비해
#     변수 이름을 서비스별로 분리해 둔다. 지금은 값만 동일.
#   * 추후 config-server(git repo) 이관 시, 이 변수들은 각 서비스 config 의
#     placeholder(${...})로 그대로 옮겨가고 값의 출처만 .env→시크릿매니저로 바뀐다.
#
# 서비스별 DB 인스턴스 / 로컬 포트 (docker-compose):
#   user 5432 · feed 5433 · ticketing 5434 · order 5435
#   notification 5436 · aiops 5437 · chat 5438
#   (auth / gateway 는 DB 미사용)
# =====================================================================


# ========== 공통 인프라 ==========
# Kafka 부트스트랩 (IntelliJ 실행=localhost:9092 EXTERNAL / 컨테이너 실행 시 kafka:29092)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- docker-compose 컨테이너 생성용 공용 계정 (현재 계정 미분리 단계) ---
# postgres/redis 컨테이너가 기동 시 이 값으로 계정/비밀번호를 만든다.
# 서비스별 *_DB_USERNAME/PASSWORD 는 "접속용"이며 현재는 이 공용값과 동일하다.
# 계정 분리(서비스별 전용 계정) 단계에서 이 공용 블록은 제거되고 서비스별 값으로 대체된다.
DB_USERNAME=root
DB_PASSWORD=password


# ========== 보안 / 시크릿 (운영=시크릿 매니저 주입, 기본값 두지 않음) ==========
# JWT Access Token 서명 키. auth 가 서명, gateway 가 검증 → 둘이 동일해야 함. 32바이트 이상.
JWT_SECRET=
# UserIdCard HMAC 서명 키. gateway 가 서명, 모든 도메인 서비스가 검증 → 전 서비스 동일. 32바이트 이상.
HMAC_SECRET_KEY=


# ========== DB: 서비스별 (계정 분리 대비 이름 분리, 현재 값은 공용) ==========
# 비밀번호만 secret(빈 값) — 각자 .env 에 채운다. URL/계정명은 로컬 기본값.

# user-service
USER_DB_URL=jdbc:postgresql://localhost:5432/user_db
USER_DB_USERNAME=root
USER_DB_PASSWORD=

# feed-service
FEED_DB_URL=jdbc:postgresql://localhost:5433/feed_db
FEED_DB_USERNAME=root
FEED_DB_PASSWORD=

# ticketing-service
TICKETING_DB_URL=jdbc:postgresql://localhost:5434/ticketing_db
TICKETING_DB_USERNAME=root
TICKETING_DB_PASSWORD=

# order-service
ORDER_DB_URL=jdbc:postgresql://localhost:5435/order_db
ORDER_DB_USERNAME=root
ORDER_DB_PASSWORD=

# notification-service
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5436/notification_db
NOTIFICATION_DB_USERNAME=root
NOTIFICATION_DB_PASSWORD=

# aiops-service
AIOPS_DB_URL=jdbc:postgresql://localhost:5437/aiops_db
AIOPS_DB_USERNAME=root
AIOPS_DB_PASSWORD=

# chat-service
CHAT_DB_URL=jdbc:postgresql://localhost:5438/chat_db
CHAT_DB_USERNAME=root
CHAT_DB_PASSWORD=

# cs-service
CS_DB_URL=jdbc:postgresql://localhost:5439/cs_db
CS_DB_USERNAME=root
CS_DB_PASSWORD=

# ========== Redis: 일반 / 티켓팅 분리 ==========
# redis 컨테이너가 기동 시 이 값으로 비밀번호를 설정하고, 각 서비스도 이 값으로 접속한다.
# (docker-compose redis-general/redis-ticketing 의 --requirepass 와 서비스 config 가 같은 변수를 공유)
# 로컬은 편의상 기본값을 제공(non-secret 취급). 운영에서는 시크릿 매니저가 동일 이름으로 주입한다.
# 일반(세션/캐시/refresh/blacklist): auth, gateway, user, feed, chat 등
REDIS_GENERAL_HOST=localhost
REDIS_GENERAL_PORT=6379
REDIS_GENERAL_PASSWORD=fandom_redis_pw
# 티켓팅(대기열/재고/분산락): ticketing, order
REDIS_TICKETING_HOST=localhost
REDIS_TICKETING_PORT=6380
REDIS_TICKETING_PASSWORD=fandom_redis_pw


# ========== feed-service: AWS S3 (이미지 업로드) ==========
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=


# ========== aiops-service ==========
# Spring AI (Gemini). CI 코드리뷰 키와는 별개 용도지만 동일 변수명.
GEMINI_API_KEY=
# Slack 장애 알림 webhook (없으면 빈 값 → 알림 비활성)
SLACK_WEBHOOK_URL=
AIOPS_KAFKA_GROUP=aiops-analysis


# ========== order-service ==========
# PG 결제 webhook 서명 검증 키
PG_WEBHOOK_SECRET_KEY=

#======== notification-service =========
FCM_ENABLED=true
FCM_CREDENTIALS_PATH=notification-service/secrets/fandom-3c639-firebase-adminsdk-fbsvc-b1b7fb5153.json