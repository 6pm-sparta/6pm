# =====================================================================
# 6pm-fandom-sns · 환경변수 템플릿 (.env.docker.example)
# =====================================================================
# .env.example과 다른 점: 여기는 "서비스(auth/gateway/ticketing 등)까지 도커로 띄우는" 경우용.
# .env.example은 원래 "인프라만 도커, 서비스는 IntelliJ 실행" 전제라 localhost 값이 맞지만,
# 서비스도 컨테이너로 띄우면 localhost가 컨테이너 자기 자신을 가리켜서 깨진다 — 대신
# docker-compose 서비스명(컨테이너 내부 DNS)으로 접속해야 한다.
#
# 사용법: cp .env.docker.example .env.docker  (docker-compose.yml의 env_file: .env.docker 로 주입됨)
# =====================================================================

# ========== 공통 인프라 ==========
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

DB_USERNAME=root
DB_PASSWORD=password

# ========== config-server: 6pm-config private 레포 인증 ==========
# GitHub Settings > Developer settings > Personal access tokens 에서 6pm-config 레포 read 권한으로 발급
CONFIG_GIT_TOKEN=
CONFIG_GIT_USERNAME=

# ========== 보안 / 시크릿 ==========
JWT_SECRET=
HMAC_SECRET_KEY=

# ========== DB: 서비스별 (컨테이너 내부 포트는 항상 5432 — 호스트 포트 매핑과 다름) ==========
USER_DB_URL=jdbc:postgresql://postgres-user:5432/user_db
USER_DB_USERNAME=root
USER_DB_PASSWORD=

FEED_DB_URL=jdbc:postgresql://postgres-feed:5432/feed_db
FEED_DB_USERNAME=root
FEED_DB_PASSWORD=

TICKETING_DB_URL=jdbc:postgresql://postgres-ticketing:5432/ticketing_db
TICKETING_DB_USERNAME=root
TICKETING_DB_PASSWORD=

ORDER_DB_URL=jdbc:postgresql://postgres-order:5432/order_db
ORDER_DB_USERNAME=root
ORDER_DB_PASSWORD=

NOTIFICATION_DB_URL=jdbc:postgresql://postgres-notification:5432/notification_db
NOTIFICATION_DB_USERNAME=root
NOTIFICATION_DB_PASSWORD=

AIOPS_DB_URL=jdbc:postgresql://postgres-aiops:5432/aiops_db
AIOPS_DB_USERNAME=root
AIOPS_DB_PASSWORD=

CHAT_DB_URL=jdbc:postgresql://postgres-chat:5432/chat_db
CHAT_DB_USERNAME=root
CHAT_DB_PASSWORD=

CS_DB_URL=jdbc:postgresql://postgres-cs:5432/cs_db
CS_DB_USERNAME=root
CS_DB_PASSWORD=

# ========== Redis: 일반 / 티켓팅 분리 (컨테이너 내부 포트는 항상 6379) ==========
REDIS_GENERAL_HOST=redis-general
REDIS_GENERAL_PORT=6379
REDIS_GENERAL_PASSWORD=fandom_redis_pw

REDIS_TICKETING_HOST=redis-ticketing
REDIS_TICKETING_PORT=6379
REDIS_TICKETING_PASSWORD=fandom_redis_pw

# ========== feed-service: AWS S3 ==========
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ========== aiops-service ==========
GEMINI_API_KEY=
SLACK_WEBHOOK_URL=
AIOPS_KAFKA_GROUP=aiops-analysis

# ========== order-service ==========
PG_WEBHOOK_SECRET_KEY=

# ========== notification-service ==========
FCM_ENABLED=true
FCM_CREDENTIALS_PATH=notification-service/secrets/fandom-3c639-firebase-adminsdk-fbsvc-b1b7fb5153.json
